{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": false,
    "sourceMap": false
  },
  "include": [
    "src/cli/**/*.ts",
    "src/lib/random-tool.ts",
    "src/lib/workspace.ts",
    "src/lib/claude-code-runner.ts",
    "src/lib/claude-settings.ts",
    "src/lib/claude-prompt.ts",
    "src/lib/turn-history.ts",
    "src/lib/agent-runner.ts",
    "src/lib/diagnostics.ts"
  ],
  "exclude": ["node_modules", "tests", "src/app"]
}
